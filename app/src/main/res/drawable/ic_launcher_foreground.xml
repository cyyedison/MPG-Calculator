<?xml version="1.0" encoding="utf-8"?>
<!--
  Fuel-efficiency gauge icon (108×108 adaptive icon foreground).
  Safe zone: 72×72 centred (from 18,18 to 90,90).

  Design: semicircular gauge arc centred at (54,68) radius 26,
  opening upward. Five tick marks at 0°/45°/90°/135°/180°
  (standard maths convention: 0° = right, 90° = up on screen).
  Red needle pointing at ~60° (right of centre = "good" MPG).
  White fuel-drop glyph below the dial.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Gauge arc: from (28,68) [left] to (80,68) [right] going UPWARD.
      sweep=0 → counterclockwise on screen → arc passes through (54,42).
    -->
    <path
        android:pathData="M 28,68 A 26,26 0 0 0 80,68"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5.5"
        android:strokeLineCap="round" />

    <!-- Gauge baseline (flat bottom of the dial housing) -->
    <path
        android:pathData="M 28,68 L 80,68"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Tick at 180° — left end (28,68) → (35,68) -->
    <path
        android:pathData="M 28,68 L 35,68"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!--
      Tick at 135°
      Arc point  (r=26): (54 + 26·cos135°, 68 − 26·sin135°) ≈ (36, 50)
      Inner point (r=19): (54 + 19·cos135°, 68 − 19·sin135°) ≈ (41, 55)
    -->
    <path
        android:pathData="M 36,50 L 41,55"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Tick at 90° — top (54,42) → (54,49) -->
    <path
        android:pathData="M 54,42 L 54,49"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!--
      Tick at 45°
      Arc point  (r=26): (54 + 26·cos45°, 68 − 26·sin45°) ≈ (72, 50)
      Inner point (r=19): (54 + 19·cos45°, 68 − 19·sin45°) ≈ (67, 55)
    -->
    <path
        android:pathData="M 72,50 L 67,55"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Tick at 0° — right end (80,68) → (73,68) -->
    <path
        android:pathData="M 80,68 L 73,68"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!--
      Needle: tail at 240° (r=6) → tip at 60° (r=22).
      Tail (54 + 6·cos240°, 68 − 6·sin240°) = (51, 73)
      Tip  (54 + 22·cos60°,  68 − 22·sin60°) = (65, 49)
      Needle points right-of-centre → "good efficiency".
    -->
    <path
        android:pathData="M 51,73 L 65,49"
        android:fillColor="#00000000"
        android:strokeColor="#FF5252"
        android:strokeWidth="4"
        android:strokeLineCap="round" />

    <!--
      Centre pivot circle: centre (54,68) radius 4.
      Two clockwise semicircles (right half then left half).
    -->
    <path
        android:pathData="M 54,64 A 4,4 0 1 1 54,72 A 4,4 0 1 1 54,64"
        android:fillColor="#FFFFFF" />

    <!--
      Fuel-drop glyph centred below the gauge.
      Tip at (54,76), widens to a circle of radius 5 at y=84.
      Straight sides meet the bottom arc at (49,84) and (59,84).
      Bottom arc: sweep=1 (clockwise) curves downward through (54,89).
    -->
    <path
        android:pathData="M 54,76 L 49,84 A 5,5 0 0 1 59,84 Z"
        android:fillColor="#FFFFFF" />

</vector>
